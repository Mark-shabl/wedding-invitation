# Database
POSTGRES_USER=wedding
POSTGRES_PASSWORD=wedding_secret
POSTGRES_DB=wedding_invites
DB_DSN=postgres://wedding:wedding_secret@postgres:5432/wedding_invites?sslmode=disable

# Redis
REDIS_URL=redis://redis:6379/0

# Backend
JWT_SECRET=change-me-in-production-use-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
PUBLIC_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
# На сервере укажите IP или домен (обязательно для входа в админку):
# PUBLIC_URL=http://192.168.88.245:3000
# ADMIN_URL=http://192.168.88.245:3001
# CORS_ORIGINS=http://192.168.88.245:3000,http://192.168.88.245:3001
# С доменом добавьте оба URL (http и https при необходимости):
# CORS_ORIGINS=http://192.168.88.245:3000,http://192.168.88.245:3001,https://wedding.example.com,https://admin.example.com
UPLOAD_DIR=/app/uploads
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Frontend: оставьте пустым — запросы идут через Next.js proxy (/api → backend)
# NEXT_PUBLIC_API_URL=

# Rate limiting
RATE_LIMIT_RPS=10
